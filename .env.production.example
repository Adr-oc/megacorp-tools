# Postgres (consumido por el servicio `postgres` y por la URL armada para `app`)
POSTGRES_USER=megatools
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=megatools

# Better Auth
BETTER_AUTH_SECRET=CHANGE_ME_openssl_rand_base64_32
BETTER_AUTH_URL=https://megatools.tu-dominio.com

# Email (Resend). Si se deja vacío, los emails caen a console.log (sólo dev).
RESEND_API_KEY=
EMAIL_FROM=no-reply@tu-dominio.com

# Puerto host expuesto por el contenedor app
APP_PORT=3000
